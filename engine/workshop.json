{
    "workshop": {
	"schema": {
	    "version": "2020.03.02"
	}
    },
    "userenvs": [
	{
	    "name": "default",
	    "requirements": [
		"engine-files",
		"engine-python-pip"
	    ]
	},
	{
	    "name": "fedora42",
	    "requirements": [
		"engine-files",
		"engine-python-distro"
	    ]
	},
	{
	    "name": "fedora43",
	    "requirements": [
		"engine-files",
		"engine-python-distro"
	    ]
	},
	{
	    "name": "fedora-latest",
	    "requirements": [
		"engine-files",
		"engine-python-distro"
	    ]
	}
    ],
    "requirements": [
	{
	    "name": "engine-files",
	    "type": "files",
	    "files_info": {
		"files": [
		    {
			"src": "%rickshaw-dir%/engine/bootstrap.py",
			"dst": "/usr/local/bin"
		    },
		    {
			"src": "%rickshaw-dir%/engine/discover-cpu-partitioning.py",
			"dst": "/usr/local/bin"
		    },
		    {
			"src": "%rickshaw-dir%/engine/partition-cpus.py",
			"dst": "/usr/local/bin"
		    }
		]
	    }
	},
	{
	    "name": "engine-python-distro",
	    "type": "distro",
	    "distro_info": {
		"packages": [
		    "python3-invoke",
		    "python3-fabric"
		]
	    }
	},
	{
	    "name": "engine-python-pip",
	    "type": "python3",
	    "python3_info": {
		"packages": [
		    "invoke",
		    "fabric"
		]
	    }
	}
    ]
}
