{
    "config": {
        "enabled": true
    },
    "capabilities": {
        "k8s-cluster": "Access to a Kubernetes cluster for deploying benchmark engines as pods",
        "remotehosts-access": "SSH access to test hosts with podman for deploying benchmark engines as containers",
        "cpu-partitioning": "Test hosts have CPU isolation configured (isolcpus, nohz_full) for latency-sensitive workloads"
    },
    "endpoints": {
        "kube": {
            "enabled": true,
            "requirements": [
                "k8s-cluster"
            ]
        },
        "remotehosts": {
            "enabled": true,
            "requirements": [
                "remotehosts-access"
            ]
        }
    },
    "runner-pools": {
        "aws-cloud-1": {
            "enabled": true,
            "provides": [
                "k8s-cluster",
                "remotehosts-access",
                "cpu-partitioning"
            ],
            "labels": [
                "self-hosted",
                "aws-cloud-1"
            ]
        }
    },
