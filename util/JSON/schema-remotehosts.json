{
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "enum": [ "remotehosts" ]
        },
        "settings": {
            "$ref": "#/definitions/settings"
        },
        "remotes": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "properties": {
                    "engines": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "object",
                            "properties": {
                                "role": {
                                    "type": "string",
                                    "enum": [ "client", "server", "profiler" ]
                                },
                                "ids": {
                                    "$ref": "#/definitions/number-lists"
                                }
                            },
                            "additionalProperties": false,
                            "required": [
                                "role",
                                "ids"
                            ]
                        }
                    },
                    "config": {
                        "type": "object",
                        "properties": {
                            "host": {
                                "type": "string",
                                "minLength": 1
                            },
                            "settings": {
                                "$ref": "#/definitions/settings"
                            }
                        },
                        "additionalProperties": false,
                        "required": [
                            "host"
                        ]
                    }
                },
                "additionalProperties": false,
                "required": [
                    "engines",
                    "config"
                ]
            }
        }
    },
    "additionalProperties": false,
    "required": [
        "type",
        "remotes"
    ],
    "definitions": {
        "settings": {
            "type": "object",
            "properties": {
                "cpu-partitioning": {
                    "type": "boolean"
                },
                "numa-node": {
                    "type": "integer",
                    "minimum": 0
                },
                "osruntime": {
                    "type": "string",
                    "minLength": 1
                },
                "userenv": {
                    "type": "string",
                    "minLength": 1
                },
                "user": {
                    "type": "string",
                    "minLength": 1
                }
            },
            "additionalProperties": false
        },
        "number-lists": {
            "anyOf": [
                {
                    "type": "integer"
                },
                {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "anyOf": [
                            {
                                "type": "string",
                                "pattern": "^(([1-9][0-9]*)(-[1-9][0-9]*)?)$"
                            },
                            {
                                "type": "integer"
                            }
                        ]
                    }
                }
            ]
        }
    }
}
